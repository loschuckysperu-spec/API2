{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install --no-audit --no-fund",
  "functions": {
    "api/datos.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/datos",
      "destination": "/api/datos"
    },
    {
      "source": "/datos/:path*",
      "destination": "/api/datos/:path*"
    }
  ]
}