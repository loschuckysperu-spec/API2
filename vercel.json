{
  "version": 2,
  "installCommand": "npm install --no-audit --no-fund",
  "buildCommand": "npm run build",
  "functions": {
    "api/datos.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/datos",
      "destination": "/api/datos"
    },
    {
      "source": "/datos/:path*",
      "destination": "/api/datos/:path*"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
